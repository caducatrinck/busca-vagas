{
  "name": "desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Busca Vagas — app desktop (Electron)",
  "main": "main.mjs",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable",
    "dist:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.caducatrinck.busca-vagas",
    "productName": "Busca Vagas",
    "copyright": "Copyright © Busca Vagas",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "app-resources",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "BuscaVagas-${version}-portable.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "artifactName": "BuscaVagas-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "artifactName": "BuscaVagas-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
